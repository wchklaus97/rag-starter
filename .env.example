# Copy to `.env` and fill in locally. Loaded by dotenvy on startup.

OPENAI_API_KEY=
# Optional: refresh docs/data/models.json with scripts/collect_openrouter_models.py
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_ANSWER_MODEL=gpt-4o-mini
ANTHROPIC_ANSWER_MODEL=claude-3-5-sonnet-latest
ANSWER_PROVIDER=openai

# --- rag-starter Rust CLI (see docs/RUST_LEARNING_TRACK.md for full env table)
# MODEL_SOURCE=ollama
# WORKSPACE_DIR=.
# RAG_ENABLE=1

# Optional NDJSON debug log (secrets redacted). Omit or leave empty to disable file logging.
# DEBUG_NDJSON_PATH=/tmp/rag-starter-debug.ndjson
# DEBUG_SESSION_ID=my-session
# DEBUG_RUN_ID=local-run

# Optional MCP server over stdio: JSON array [program, ...args]. Exposes tool `call_mcp_stdio_tool`.
# SECURITY: arbitrary subprocess — only trusted binaries on trusted machines.
# RAG_STARTER_MCP_STDIO_JSON='[\"npx\", \"-y\", \"@some/mcp-server\"]'
